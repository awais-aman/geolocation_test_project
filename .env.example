RACK_ENV=development
PORT=3000
# Host port for Docker (container still listens on 3000 inside)
APP_PORT=3001

# PostgreSQL — defaults come from config/database.yml; override here if needed
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
# DATABASE_NAME=geolocation_api_development

IPSTACK_ACCESS_KEY=your_ipstack_access_key_here
GEOLOCATION_PROVIDER=ipstack
