#!/usr/bin/env bash
# Run any command inside the web container.
# Usage: bin/run bundle exec rake db:seed
set -euo pipefail

cd "$(dirname "$0")/.."

if ! docker compose ps --status running --services 2>/dev/null | grep -qx web; then
  echo "Containers not running. Run: make up"
  exit 1
fi

exec docker compose exec web "$@"
